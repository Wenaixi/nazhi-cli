# ─── nazhi-cli 环境变量模板 ─────────────────────────────────
# 复制为 .env 填入真实值（.env 已在 .gitignore，不会提交）
#   cp .env.example .env

# SSO 登录账号
NAZHI_USERNAME=your_student_number
NAZHI_PASSWORD=your_password

# SSO 根地址（可选，默认 https://www.nazhisoft.com）
# NAZHI_SSO_BASE=https://www.nazhisoft.com

# 业务 API 根地址（可选，默认 http://139.159.205.146:8280）
# NAZHI_BASE_URL=http://139.159.205.146:8280

# 上传服务器（可选，默认 http://doc.nazhisoft.com）
# NAZHI_UPLOAD_URL=http://doc.nazhisoft.com

# HTTP 超时秒数（可选，默认 15）
# NAZHI_TIMEOUT=30

# 登录后获取的 token（其他命令 session/whoami/task/self-eval 也会用）
# 留空则必须先跑 `nazhi login`
# NAZHI_TOKEN=eyJhbGciOiJIUzI1NiJ9.xxxxx
